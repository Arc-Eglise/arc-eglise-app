# ═══════════════════════════════════════════════════════════════════════════════
# ARC Église — Variables d'environnement
# Copier ce fichier en .env.local et remplir toutes les valeurs
# NE JAMAIS committer .env.local — il est dans .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase ARC (projet dédié fobyvhulyjxwbhusouqz — Frankfurt eu-central-1) ─
# Dashboard : https://supabase.com/dashboard/project/fobyvhulyjxwbhusouqz/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://fobyvhulyjxwbhusouqz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── URL publique du site ──────────────────────────────────────────────────────
# En prod : https://arc-eglise.ch (quand le domaine sera actif)
# En preview Vercel : URL générée automatiquement
# En local : http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Bible API (scripture.api.bible) ──────────────────────────────────────────
# Créer un compte sur https://scripture.api.bible et générer une clé
BIBLE_API_KEY=
BIBLE_API_BASE=https://api.scripture.api.bible/v1
# ID de la traduction par défaut (ex: 6f26e199139ea7f1-01 = La Bible du Semeur FR)
BIBLE_DEFAULT_ID=

# ── Lunziko Platform API ──────────────────────────────────────────────────────
# Architecture : ARC Église → Lunziko Platform API (JAMAIS LunzikoEngine directement)
# URL prod : https://api-gules-nine-89.vercel.app/v1
LUNZIKO_API_URL=
LUNZIKO_SUPABASE_URL=
LUNZIKO_SUPABASE_ANON_KEY=
LUNZIKO_EMAIL=
LUNZIKO_PASSWORD=

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Google Cloud Console → APIs → YouTube Data API v3
YOUTUBE_API_KEY=
# Trouvable dans l'URL de la chaîne : youtube.com/channel/UCxxxxxx
YOUTUBE_CHANNEL_ID=

# ── Chiffrement clés IA personnelles membres ──────────────────────────────────
# Exactement 32 caractères — garder secret, ne jamais committer
ARC_ENCRYPTION_KEY=

# ── Google Search Console (débloqué quand arc-eglise.ch sera actif) ──────────
# Ajouter dans Vercel env vars uniquement (ne pas mettre en local)
# GOOGLE_SITE_VERIFICATION=
