## ═══════════════════════════════════════════════════════════════════════════
## PROJET : ARC Église (arc-eglise.ch)
## Compte propriétaire de TOUS les services ARC : arceglise.cdf@gmail.com
## Copier ce fichier en .env.local et remplir toutes les valeurs
## NE JAMAIS committer .env.local — il est dans .gitignore
## ═══════════════════════════════════════════════════════════════════════════

## ── SUPABASE ARC ÉGLISE ──────────────────────────────────────────────────
## Compte : arceglise.cdf@gmail.com
## Dashboard : https://supabase.com/dashboard/project/fobyvhulyjxwbhusouqz/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://fobyvhulyjxwbhusouqz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

## ── URL DU SITE ARC ÉGLISE ───────────────────────────────────────────────
## En prod : https://arc-eglise.ch | En local : http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

## ── BIBLE API ────────────────────────────────────────────────────────────
## Compte : arceglise.cdf@gmail.com sur https://scripture.api.bible
BIBLE_API_KEY=
BIBLE_API_BASE=https://api.scripture.api.bible/v1
BIBLE_DEFAULT_ID=

## ── CHIFFREMENT (clés IA membres) ────────────────────────────────────────
## Exactement 32 caractères — garder secret, ne jamais committer
ARC_ENCRYPTION_KEY=

## ── STRIPE ───────────────────────────────────────────────────────────────
## Compte : arceglise.cdf@gmail.com
## Utiliser clés TEST (sk_test_ / pk_test_) jusqu'à activation TWINT
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

## ── MICROSOFT GRAPH API (boîtes mail @arc-eglise.ch) ───────────────────
## App Registration dans Azure Portal sous arceglise.cdf@gmail.com
## Permissions requises : Mail.Read, Mail.ReadWrite, Mail.Send
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

## ── YOUTUBE (chaîne ARC Église) ─────────────────────────────────────────
## Compte Google : arceglise.cdf@gmail.com → Google Cloud Console → YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

## ── RESEND (emails transactionnels) ─────────────────────────────────────
## Compte : arceglise.cdf@gmail.com sur https://resend.com
RESEND_API_KEY=

## ── GOOGLE SEARCH CONSOLE ────────────────────────────────────────────────
## Compte : arceglise.cdf@gmail.com — ajouter uniquement dans Vercel (pas en local)
# GOOGLE_SITE_VERIFICATION=

## ═══════════════════════════════════════════════════════════════════════════
## PROJET EXTERNE : Lunziko Platform (projet séparé — consommé par ARC Église)
##
## ARC Église est un CLIENT de la Lunziko Platform API.
## Ces credentials sont des identifiants de compte de service Lunziko :
## ils permettent à ARC Église d'appeler l'API Lunziko pour les fonctions IA.
## Ils N'APPARTIENNENT PAS à ARC Église — ne pas les confondre avec les
## variables ARC ci-dessus. Contact : projet Lunziko pour obtenir ces valeurs.
## ═══════════════════════════════════════════════════════════════════════════
LUNZIKO_API_URL=
LUNZIKO_SUPABASE_URL=
LUNZIKO_SUPABASE_ANON_KEY=
LUNZIKO_EMAIL=
LUNZIKO_PASSWORD=
